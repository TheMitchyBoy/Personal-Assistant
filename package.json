{
  "name": "operator",
  "version": "0.1.0",
  "private": true,
  "description": "Operator — a personal-assistant + business-analyst for a dev side-hustle. Cron job + SQLite + Telegram bot.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "daily": "tsx src/daily.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "telegraf": "^4.16.3",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.3"
  }
}
