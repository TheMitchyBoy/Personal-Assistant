TELEGRAM_BOT_TOKEN=        # from @BotFather
TELEGRAM_CHAT_ID=          # my numeric chat id
DAILY_TIME=07:30           # 24h local time for the daily nudge
CHECKIN_TIME=20:00         # 24h local time for the evening check-in
STALL_DAYS=4               # an active project with no progress in this many days is "stalling"
TZ=America/Chicago         # for cron correctness
ANTHROPIC_API_KEY=         # enables the web "Assistant" AI chat agent; leave blank to disable
ANTHROPIC_MODEL=claude-sonnet-4-6   # model for the AI agent (override if needed)
DATABASE_PATH=             # local: leave blank (data/operator.db). Railway: /data/operator.db on a persistent volume
DASHBOARD_PASSWORD=        # set to enable the web dashboard (left blank = dashboard off)
PORT=3000                  # web dashboard port (Railway sets this automatically)
